<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Painel Administrativo</title>
    <link rel="stylesheet" href="style.css">
</head>
<body>

    <div id="admin" class="view active">
        <h2>Painel Administrativo</h2>

        <h3>Homologação de Candidaturas</h3>

        <table>
            <% Candidatos.forEach(function(candidato) { %>
            <% if (candidato.status === 'Pendente') { %>
            <tr>
                <th>Candidato</th>
                <th>Número</th>
                <th>Status</th>
                <th>Ações</th>
            </tr>

            <tr>
                <td><%= candidato.nome %></td>
                <td><%= candidato.numero %></td>
                <td><%= candidato.status %></td>
                <td>
                    <button style="background-color: #2ecc71; padding: 5px 10px;">Aprovar</button>
                    <button style="background-color: #e74c3c; padding: 5px 10px;">Rejeitar</button>
                </td>
            </tr>
            <% } %>
            <% }) %>  
        </table>

        <br>
        <a href="/login">← Voltar</a>
    </div>

    <script>

    </script>

</body>
</html>