<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Painel Administrativo</title>
    <link rel="stylesheet" href="style.css">
</head>
<body>

    <div id="admin" class="view active">
        <h2>Painel Administrativo</h2>

        <h3>Homologação de Candidaturas</h3>

        <table>
            <tr>
                <th>Candidato</th>
                <th>Número</th>
                <th>Status</th>
                <th>Ações</th>
            </tr>

            <tr>
                <td>João Silva</td>
                <td>12</td>
                <td id="status-joao" class="status-pendente">Pendente</td>
                <td>
                    <button onclick="aprovar('joao')" style="background-color: #2ecc71; padding: 5px 10px;">Aprovar</button>
                    <button onclick="rejeitar('joao')" style="background-color: #e74c3c; padding: 5px 10px;">Rejeitar</button>
                </td>
            </tr>
        </table>

        <br>
        <a href="/">← Voltar</a>
    </div>

    <script>
        function aprovar(id) {
            document.getElementById(`status-${id}`).innerText = "Aprovado";
            alert("Candidatura aprovada!");
        }

        function rejeitar(id) {
            document.getElementById(`status-${id}`).innerText = "Rejeitado";
            alert("Candidatura rejeitada!");
        }
    </script>

</body>
</html>