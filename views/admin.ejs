<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Painel Administrativo</title>
    <link rel="stylesheet" href="style.css">
    <style>
        .stats-container {
            display: flex;
            gap: 20px;
            margin-bottom: 30px;
        }
        .stat-card {
            flex: 1;
            padding: 15px;
            border-radius: 8px;
            text-align: center;
            background: #fff;
            box-shadow: 0 2px 5px rgba(0,0,0,0.1);
            border: 1px solid #ddd;
        }
        .stat-card h4 { margin: 0; color: #666; font-size: 14px; }
        .stat-card p { margin: 5px 0 0; font-size: 24px; font-weight: bold; }
        
        .section-title {
            margin-top: 40px;
            padding-bottom: 10px;
            border-bottom: 2px solid #eee;
            color: #333;
        }
        
        table { width: 100%; border-collapse: collapse; margin-top: 10px; background: white; }
        th, td { padding: 12px; text-align: left; border-bottom: 1px solid #eee; }
        th { background-color: #f8f9fa; }
        
        .badge {
            padding: 4px 8px;
            border-radius: 4px;
            font-size: 12px;
            font-weight: bold;
            color: white;
        }
        .bg-success { background-color: #2ecc71; }
        .bg-danger { background-color: #e74c3c; }
        .bg-warning { background-color: #f1c40f; color: #333; }
    </style>
</head>
<body style="background-color: #f4f7f6; font-family: sans-serif; padding: 20px;">

    <div id="admin" style="max-width: 1100px; margin: 0 auto;">
        <h2>Painel Administrativo</h2>

        <% 
            let totalRecebidos = Candidatos.length;
            let totalAprovados = Candidatos.filter(c => c.status === 'Homologado').length;
            let totalRejeitados = Candidatos.filter(c => c.status === 'Rejeitado').length;
            let totalPendentes = Candidatos.filter(c => c.status === 'Pendente').length;
        %>
        <div class="stats-container">
            <div class="stat-card">
                <h4>Total Recebidos</h4>
                <p><%= totalRecebidos %></p>
            </div>
            <div class="stat-card">
                <h4>Pendentes</h4>
                <p style="color: #f1c40f;"><%= totalPendentes %></p>
            </div>
            <div class="stat-card">
                <h4>Aprovados</h4>
                <p style="color: #2ecc71;"><%= totalAprovados %></p>
            </div>
            <div class="stat-card">
                <h4>Rejeitados</h4>
                <p style="color: #e74c3c;"><%= totalRejeitados %></p>
            </div>
        </div>

        <h3 class="section-title">Aguardando Homologação</h3>
        <table>
            <thead>
                <tr>
                    <th>Candidato</th>
                    <th>Número</th>
                    <th>Status</th>
                    <th>Ações</th>
                </tr>
            </thead>
            <tbody>
                <% let temPendente = false; %>
                <% Candidatos.forEach(function(candidato) { %>
                    <% if (candidato.status === 'Pendente') { %>
                        <% temPendente = true; %>
                        <tr id="linha-<%= candidato._id %>">
                            <td><%= candidato.nome %></td>
                            <td><%= candidato.numero %></td>
                            <td><span class="badge bg-warning">Pendente</span></td>
                            <td>
                                <button onclick="mudarStatus('<%= candidato._id %>', 'Homologado')" style="background-color: #2ecc71; color: white; padding: 5px 10px; border: none; cursor: pointer; border-radius: 4px;">Aprovar</button>
                                <button onclick="mudarStatus('<%= candidato._id %>', 'Rejeitado')" style="background-color: #e74c3c; color: white; padding: 5px 10px; border: none; cursor: pointer; border-radius: 4px;">Rejeitar</button>
                            </td>
                        </tr>
                    <% } %>
                <% }) %>
                <% if (!temPendente) { %>
                    <tr><td colspan="4" style="text-align: center; color: #999;">Nenhuma candidatura pendente no momento.</td></tr>
                <% } %>
            </tbody>
        </table>

        <h3 class="section-title">Histórico de Decisões</h3>
        <table>
            <thead>
                <tr>
                    <th>Candidato</th>
                    <th>Número</th>
                    <th>Cargo</th>
                    <th>Status Final</th>
                </tr>
            </thead>
            <tbody>
                <% let temHistorico = false; %>
                <% Candidatos.forEach(function(candidato) { %>
                    <% if (candidato.status !== 'Pendente') { %>
                        <% temHistorico = true; %>
                        <tr>
                            <td><%= candidato.nome %></td>
                            <td><%= candidato.numero %></td>
                            <td><%= candidato.cargo %></td>
                            <td>
                                <span class="badge <%= candidato.status === 'Homologado' ? 'bg-success' : 'bg-danger' %>">
                                    <%= candidato.status %>
                                </span>
                            </td>
                        </tr>
                    <% } %>
                <% }) %>
                <% if (!temHistorico) { %>
                    <tr><td colspan="4" style="text-align: center; color: #999;">O histórico aparecerá aqui após as primeiras homologações.</td></tr>
                <% } %>
            </tbody>
        </table>

        <br><br>
        <a href="<%= linkHome %>" style="text-decoration: none; color: #555;">← Voltar para Home</a>
    </div>

    <script>
        async function mudarStatus(candidatoId, novoStatus) {
            const acao = novoStatus === 'Homologado' ? 'aprovar' : 'rejeitar';
            if (!confirm(`Tem certeza que deseja ${acao} este candidato?`)) return;

            try {
                const response = await fetch('/admin/homologar', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ candidatoId, novoStatus })
                });

                const data = await response.json();

                if (response.ok) {
                    alert(data.message);
                    window.location.reload();
                } else {
                    alert("Erro: " + data.message);
                }
            } catch (error) {
                console.error("Erro na requisição:", error);
                alert("Ocorreu um erro ao processar a solicitação.");
            }
        }
    </script>
</body>
</html>