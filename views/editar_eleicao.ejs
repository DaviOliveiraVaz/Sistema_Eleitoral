<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Editar Eleição</title>
    <link rel="stylesheet" href="/style.css">
</head>
<body>
    <%- include('navbar') %>

    <div class="container">
        <div class="login-wrapper" style="max-width:520px; margin:40px auto;">
            <div class="login-header">
                <h1>✏️ Editar Eleição</h1>
                <p>Atualize os dados da eleição selecionada</p>
            </div>

            <form method="POST" action="/eleicoes/editar/<%= eleicao._id %>" style="padding:30px;">

                <% if (eleicao.ativa) { %>
                <div style="background:#fef9e7; border:1px solid #f9e79f; border-radius:6px; padding:12px 16px; margin-bottom:20px; color:#7d6608; font-size:0.9rem;">
                    ⚠️ Esta eleição está <strong>ativa no momento</strong>. Alterações afetarão a votação em andamento.
                </div>
                <% } %>

                <div class="form-group">
                    <label for="nome">Nome da Eleição</label>
                    <input type="text" id="nome" name="nome" value="<%= eleicao.nome %>" required>
                </div>

                <div class="form-group">
                    <label for="tipo">Tipo de Eleição</label>
                    <select id="tipo" name="tipo" required
                            style="width:100%; padding:10px; border-radius:4px; border:1px solid #ccc; font-size:1rem;">
                        <option value="Geral"     <%= eleicao.tipo === 'Geral'     ? 'selected' : '' %>>Geral</option>
                        <option value="Municipal" <%= eleicao.tipo === 'Municipal' ? 'selected' : '' %>>Municipal</option>
                    </select>
                    <p id="tipo-info" style="font-size:0.82rem; color:#7f8c8d; margin-top:6px;"></p>
                </div>

                <div style="display:flex; gap:12px; margin-top:10px;">
                    <a href="/eleicoes" class="btn btn-voltar" style="flex:1; text-align:center; text-decoration:none; display:flex; align-items:center; justify-content:center;">
                        Cancelar
                    </a>
                    <button type="submit" class="btn btn-primary" style="flex:1;">
                        Salvar Alterações
                    </button>
                </div>
            </form>
        </div>
    </div>

    <script>
        const select = document.getElementById('tipo');
        const info   = document.getElementById('tipo-info');
        const descricoes = {
            'Geral':     'Cargos: Presidente, Governador, Senador, Deputado Federal e Estadual.',
            'Municipal': 'Cargos: Prefeito e Vereador. Filtragem por cidade do eleitor.'
        };
        function atualizar() { info.textContent = descricoes[select.value] || ''; }
        select.addEventListener('change', atualizar);
        atualizar();
    </script>
</body>
</html>
