<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <title>Home - Admin</title>
    <link rel="stylesheet" href="style.css">
</head>
<body>
    <%- include('navbar') %>

    <main class="content-area">
        <h1>Painel Administrativo</h1>
        <p>Gerencie as solicitações de candidatura e acompanhe o sistema.</p>

        <div style="display: grid; grid-template-columns: repeat(4, 1fr); gap: 20px; margin-top: 30px; max-width: 700px;">
            <a href="/admin" class="login-card" style="text-decoration:none;">
                <div class="card-icon">✅</div>
                <h3>Homologação</h3>
                <p>Aprovar ou rejeitar candidaturas pendentes</p>
            </a>
            <a href="/consulta_candidatos" class="login-card" style="text-decoration:none;">
                <div class="card-icon">🔍</div>
                <h3>Gerenciar Candidatos</h3>
                <p>Editar e inativar candidatos e candidaturas</p>
            </a>
            <a href="/consulta_eleitores" class="login-card" style="text-decoration:none;">
                <div class="card-icon">🔍</div>
                <h3>Gerenciar Eleitores</h3>
                <p>Editar e inativar candidatos</p>
            </a>
            <a href="/resultados" class="login-card" style="text-decoration:none;">
                <div class="card-icon">📊</div>
                <h3>Apuração</h3>
                <p>Acompanhar resultado dos votos</p>
            </a>
        </div>
    </main>
</body>
</html>
