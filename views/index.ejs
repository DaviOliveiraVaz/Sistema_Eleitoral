<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Sistema de Eleições Universitárias</title>
    <link rel="stylesheet" href="style.css">
</head>
<body>
    <header>
        <h1>Sistema Integrado de Eleições</h1>
    </header>
    
    <nav id="mainNav">
        <button onclick="switchView('login')">Sair</button>
        <button onclick="switchView('urna')" id="nav-urna" style="display:none;">Urna</button>
        <button onclick="switchView('candidato')" id="nav-candidato" style="display:none;">Área do Candidato</button>
        <button onclick="switchView('admin')" id="nav-admin" style="display:none;">Painel Admin</button>
        <button onclick="switchView('resultados')" id="nav-resultados" style="display:none;">Resultados</button>
    </nav>

    <div class="container">
        <div id="login" class="view active">
            <h2>Selecione seu Perfil de Acesso</h2>
            <div class="login-options">
                <div class="login-card" onclick="loginComo('eleitor')">
                    <h3>🗳️ Eleitor</h3>
                    <p>Acessar a urna para votar</p>
                </div>
                <div class="login-card" onclick="loginComo('candidato')">
                    <h3>👤 Candidato</h3>
                    <p>Lançar ou acompanhar candidatura</p>
                </div>
                <div class="login-card" onclick="loginComo('admin')">
                    <h3>⚙️ Administrador</h3>
                    <p>Gerenciar eleições e resultados</p>
                </div>
            </div>
        </div>

        <div id="urna" class="view">
            <h2>Votação</h2>
            <div class="urna-container">
                <div class="urna-tela">
                    <div>
                        <div class="tela-header">Seu voto para<br><br>REPRESENTANTE DISCENTE</div>
                        <div class="tela-numeros">
                            <div class="digito" id="digito1"></div>
                            <div class="digito" id="digito2"></div>
                        </div>
                        <div id="info-candidato" style="font-size: 1.2rem; font-weight: bold; min-height: 60px;"></div>
                    </div>
                    <div class="tela-rodape">
                        Aperte a tecla:<br>
                        VERDE para CONFIRMAR<br>
                        LARANJA para CORRIGIR
                    </div>
                </div>
                <div class="urna-teclado">
                    <div class="teclado-numeros">
                        <button class="tecla" onclick="inserirNumero(1)">1</button>
                        <button class="tecla" onclick="inserirNumero(2)">2</button>
                        <button class="tecla" onclick="inserirNumero(3)">3</button>
                        <button class="tecla" onclick="inserirNumero(4)">4</button>
                        <button class="tecla" onclick="inserirNumero(5)">5</button>
                        <button class="tecla" onclick="inserirNumero(6)">6</button>
                        <button class="tecla" onclick="inserirNumero(7)">7</button>
                        <button class="tecla" onclick="inserirNumero(8)">8</button>
                        <button class="tecla" onclick="inserirNumero(9)">9</button>
                        <div></div>
                        <button class="tecla" onclick="inserirNumero(0)">0</button>
                        <div></div>
                    </div>
                    <div class="teclado-acoes">
                        <button class="tecla-acao tecla-branco" onclick="votarBranco()">Branco</button>
                        <button class="tecla-acao tecla-corrige" onclick="corrigirVoto()">Corrige</button>
                        <button class="tecla-acao tecla-confirma" onclick="confirmarVoto()">Confirma</button>
                    </div>
                </div>
            </div>
        </div>

        <div id="candidato" class="view">
            <h2>Lançar Candidatura</h2>
            <div class="form-group">
                <label>Nome Completo</label>
                <input type="text" placeholder="Seu nome">
            </div>
            <div class="form-group">
                <label>Número de Campanha (2 dígitos)</label>
                <input type="number" placeholder="Ex: 42">
            </div>
            <button class="btn btn-primary" onclick="alert('Candidatura enviada para análise do Admin!')">Enviar para Homologação</button>
            
            <h3 style="margin-top: 30px;">Status da Candidatura</h3>
            <p>Sua solicitação está: <span class="status-pendente">Em Análise (Pendente)</span></p>
        </div>

        <div id="admin" class="view">
            <h2>Painel Administrativo</h2>
            <h3>Homologação de Candidaturas</h3>
            <table>
                <tr>
                    <th>Candidato</th>
                    <th>Número</th>
                    <th>Status</th>
                    <th>Ações</th>
                </tr>
                <tr>
                    <td>João Silva</td>
                    <td>12</td>
                    <td class="status-pendente">Pendente</td>
                    <td>
                        <button class="btn btn-primary" style="background-color: #2ecc71; padding: 5px 10px;">Aprovar</button>
                        <button class="btn btn-primary" style="background-color: #e74c3c; padding: 5px 10px;">Rejeitar</button>
                    </td>
                </tr>
            </table>
        </div>

        <div id="resultados" class="view">
            <h2>Resultados Parciais</h2>
            <div style="display: flex; gap: 20px; margin-top: 20px;">
                <div style="flex: 1; border: 1px solid #ddd; padding: 20px; border-radius: 8px;">
                    <h3>Ranking</h3>
                    <ul style="list-style: none; margin-top: 15px; line-height: 2;">
                        <li><strong>1º</strong> - João Silva (12) - 45% dos votos</li>
                        <li><strong>2º</strong> - Maria Souza (42) - 30% dos votos</li>
                        <li><strong>3º</strong> - Votos Brancos/Nulos - 25%</li>
                    </ul>
                </div>
                <div style="flex: 1; border: 1px solid #ddd; padding: 20px; border-radius: 8px; display: flex; align-items: center; justify-content: center; background-color: #fafafa;">
                    <p style="color: #888;">[ Espaço reservado para gráficos com Chart.js ]</p>
                </div>
            </div>
        </div>
    </div>

    <script>
        // Lógica de Navegação
        function switchView(viewId) {
            document.querySelectorAll('.view').forEach(el => el.classList.remove('active'));
            document.getElementById(viewId).classList.add('active');
            
            const nav = document.getElementById('mainNav');
            if (viewId === 'login') {
                nav.style.display = 'none';
            } else {
                nav.style.display = 'block';
            }
        }

        function loginComo(perfil) {
            document.getElementById('nav-urna').style.display = 'none';
            document.getElementById('nav-candidato').style.display = 'none';
            document.getElementById('nav-admin').style.display = 'none';
            document.getElementById('nav-resultados').style.display = 'none';

            if (perfil === 'eleitor') {
                document.getElementById('nav-urna').style.display = 'inline-block';
                switchView('urna');
            } else if (perfil === 'candidato') {
                document.getElementById('nav-candidato').style.display = 'inline-block';
                switchView('candidato');
            } else if (perfil === 'admin') {
                document.getElementById('nav-admin').style.display = 'inline-block';
                document.getElementById('nav-resultados').style.display = 'inline-block';
                switchView('admin');
            }
        }

        // Lógica da Urna Mock
        let votoAtual = "";
        
        function atualizarTela() {
            document.getElementById('digito1').innerText = votoAtual[0] || "";
            document.getElementById('digito2').innerText = votoAtual[1] || "";
            
            const info = document.getElementById('info-candidato');
            if (votoAtual.length === 2) {
                // Mock de candidato
                if (votoAtual === "12") info.innerText = "Candidato: João Silva";
                else if (votoAtual === "42") info.innerText = "Candidato: Maria Souza";
                else info.innerText = "VOTO NULO";
            } else {
                info.innerText = "";
            }
        }

        function inserirNumero(num) {
            if (votoAtual.length < 2) {
                votoAtual += num;
                atualizarTela();
            }
        }

        function corrigirVoto() {
            votoAtual = "";
            document.getElementById('info-candidato').innerText = "";
            atualizarTela();
        }

        function votarBranco() {
            votoAtual = "";
            atualizarTela();
            document.getElementById('info-candidato').innerText = "VOTO EM BRANCO";
        }

        function confirmarVoto() {
            if (votoAtual.length === 2 || document.getElementById('info-candidato').innerText === "VOTO EM BRANCO") {
                // Toca aquele barulhinho clássico "PILI-LI-LIIIII" aqui se quiser colocar um audio.play()
                alert("FIM! Voto computado com sucesso.");
                corrigirVoto();
                switchView('login'); // Volta pro início
            } else {
                alert("Digite o número completo do candidato antes de confirmar.");
            }
        }
    </script>
</body>
</html>