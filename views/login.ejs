<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Sistema Eleitoral - Acesso</title>
    <link rel="stylesheet" href="style.css">
</head>
<body class="login-page">
    
    <div class="login-wrapper">
        <header class="login-header">
            <h1>Sistema Eleitoral</h1>
            <p>Escolha o seu perfil de acesso para continuar</p>
        </header>
        
        <div class="login-options">
            
            <div class="login-card" onclick="window.location.href='/urna'">
                <div class="card-icon">🗳️</div>
                <h3>Eleitor</h3>
                <p>Acessar a urna para votar no seu candidato.</p>
            </div>

            <div class="login-card" onclick="window.location.href='/candidato'">
                <div class="card-icon">👤</div>
                <h3>Candidato</h3>
                <p>Visualizar e lançar dados da candidatura.</p>
            </div>

            <div class="login-card" onclick="window.location.href='/admin'">
                <div class="card-icon">⚙️</div>
                <h3>Administrador</h3>
                <p>Gerenciar candidatos e apuração dos votos.</p>
            </div>
            
        </div>

        <footer class="login-footer">
            <button class="btn btn-voltar" onclick="window.location.href='/'">⬅ Voltar ao Início</button>
        </footer>
    </div>

</body>
</html>