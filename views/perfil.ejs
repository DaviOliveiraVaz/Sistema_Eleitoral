<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <title>Meu Perfil</title>
    <link rel="stylesheet" href="style.css">
</head>
<body>
    <%- include('navbar') %>

    <main class="content-area">
        <div class="login-wrapper" style="max-width: 700px; margin: 0 auto;">
            <header class="login-header">
                <h1>Meus Dados</h1>
                <p>Gerencie suas informações pessoais</p>
            </header>

            <form action="/perfil/editar" method="POST" style="padding: 30px;">
                <div class="form-group">
                    <label>Nome Completo</label>
                    <input type="text" name="nome" value="<%= usuario.nome %>" required>
                </div>

                <div style="display: flex; gap: 15px;">
                    <div class="form-group" style="flex: 1;">
                        <label>CPF (Apenas Leitura)</label>
                        <input type="text" value="<%= usuario.cpf %>" disabled style="background-color: #eee;">
                    </div>
                    <div class="form-group" style="flex: 1;">
                        <label>Data de Nascimento</label>
                        <input type="date" name="dataNascimento" value="<%= usuario.dataNascimento ? usuario.dataNascimento.toISOString().split('T')[0] : '' %>" required style="width: 100%; padding: 10px; border: 1px solid #ccc; border-radius: 4px;">
                    </div>
                </div>

                <div class="instructions-container">
                    <div class="form-group" style="flex: 1;">
                        <label>Estado (UF)</label>
                        <select name="estado" id="estado" required style="width: 100%; padding: 10px; border-radius: 4px; border: 1px solid #ccc;">
                            <option value="<%= usuario.estado %>" selected><%= usuario.estado %></option>
                        </select>
                    </div>
                    <div class="form-group" style="flex: 2;">
                        <label>Cidade</label>
                        <select name="cidade" id="cidade" required style="width: 100%; padding: 10px; border-radius: 4px; border: 1px solid #ccc;">
                            <option value="<%= usuario.cidade %>" selected><%= usuario.cidade %></option>
                        </select>
                    </div>
                </div>

                <div class="form-group">
                    <label>Situação do Voto</label>
                    <div style="margin-top: 5px;">
                        <% if (usuario.votou) { %>
                            <span class="status-aprovado" style="background-color: #d4edda; padding: 6px 12px; border-radius: 4px;">
                                ● Voto Confirmado
                            </span>
                        <% } else { %>
                            <span class="status-rejeitado" style="background-color: #f8d7da; padding: 6px 12px; border-radius: 4px;">
                                ○ Ainda não votou
                            </span>
                        <% } %>
                    </div>
                </div>

                <% if (tipoAcesso === 'Candidato' && usuario.cargo) { %>
                    <div class="instruction-item" style="text-align: left; margin-bottom: 20px; background-color: #f0f7ff;">
                        <h4 style="color: #3498db;">Dados da Candidatura</h4>
                        <p><strong>Cargo:</strong> <%= usuario.cargo %></p>
                        <p><strong>Número:</strong> <%= usuario.numero %></p>
                        <p><strong>Status:</strong> <%= usuario.status %></p>
                    </div>
                <% } %>

                <button type="submit" class="btn btn-primary" style="width: 100%;">Salvar Alterações</button>
            </form>
        </div>
    </main>
    <script>
        const ufSelect = document.getElementById('estado');
        const cidadeSelect = document.getElementById('cidade');
        const ufSalva = "<%= usuario.estado || '' %>";
        const cidadeSalva = "<%= usuario.cidade || '' %>";
        fetch('https://servicodados.ibge.gov.br/api/v1/localidades/estados?orderBy=nome')
            .then(res => res.json())
            .then(estados => {
                ufSelect.innerHTML = '<option value="" disabled>Selecione o Estado</option>';
                estados.forEach(estado => {
                    const selected = estado.sigla === ufSalva ? 'selected' : '';
                    ufSelect.innerHTML += `<option value="${estado.sigla}" ${selected}>${estado.nome}</option>`;
                });
                if (ufSalva) {
                    carregarCidades(ufSalva, cidadeSalva);
                }
            })
            .catch(erro => console.error(erro));
        ufSelect.addEventListener('change', () => {
            carregarCidades(ufSelect.value, '');
        });
        function carregarCidades(uf, cidadeSelecionada) {
            cidadeSelect.innerHTML = '<option value="">Carregando...</option>';
            cidadeSelect.disabled = true;
            fetch(`https://servicodados.ibge.gov.br/api/v1/localidades/estados/${uf}/municipios`)
                .then(res => res.json())
                .then(cidades => {
                    cidadeSelect.innerHTML = '<option value="" disabled>Selecione a cidade</option>';
                    cidades.forEach(cidade => {
                        const selected = city.nome === cidadeSelecionada || cidade.nome === cidadeSelecionada ? 'selected' : '';
                        cidadeSelect.innerHTML += `<option value="${cidade.nome}" ${selected}>${cidade.nome}</option>`;
                    });
                    cidadeSelect.disabled = false;
                })
                .catch(erro => console.error(erro));
        }
    </script>
</body>
</html>