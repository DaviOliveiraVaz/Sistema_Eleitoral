<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <title>Meu Perfil</title>
    <link rel="stylesheet" href="/style.css">
    <script src="https://cdnjs.cloudflare.com/ajax/libs/html2pdf.js/0.10.1/html2pdf.bundle.min.js"></script>
</head>
<body>
    <%- include('navbar') %>

    <main class="content-area">
        <div class="login-wrapper" style="max-width: 700px; margin: 0 auto;">
            <header class="login-header">
                <h1>Meus Dados</h1>
                <p>Gerencie suas informações pessoais</p>
            </header>

            <form action="/perfil/editar" method="POST" style="padding: 30px;">
                <div class="form-group">
                    <label>Nome Completo</label>
                    <input type="text" name="nome" value="<%= usuario.nome %>" required disabled>
                </div>

                <div style="display: flex; gap: 15px;">
                    <div class="form-group" style="flex: 1;">
                        <label>CPF</label>
                        <input type="text" value="<%= usuario.cpf %>" disabled style="background-color: #eee;">
                    </div>
                    <div class="form-group" style="flex: 1;">
                        <label>Data de Nascimento</label>
                        <% 
                            let dataFormatada = '';
                            if (usuario.dataNascimento) {
                                const d = new Date(usuario.dataNascimento);
                                dataFormatada = d.toISOString().split('T')[0];
                            }
                        %>
                        <input type="date" name="dataNascimento" value="<%= dataFormatada %>" disabled required style="width: 100%; padding: 10px; border: 1px solid #ccc; border-radius: 4px;">
                    </div>
                </div>

                <div class="form-group">
                    <label>Idade Atual</label>
                    <input type="number" value="<%= usuario.idade %>" disabled style="background-color: #eee;">
                </div>

                <div class="form-group">
                    <label>Sexo</label>
                    <select name="sexo" required style="width: 100%; padding: 10px; border-radius: 4px; border: 1px solid #ccc;" disabled>
                        <option value="" disabled <%= !usuario.sexo ? 'selected' : '' %>>Selecione</option>
                        <option value="Masculino" <%= usuario.sexo === 'Masculino' ? 'selected' : '' %>>Masculino</option>
                        <option value="Feminino" <%= usuario.sexo === 'Feminino' ? 'selected' : '' %>>Feminino</option>
                    </select>
                </div>

                <div class="instructions-container" style="display: flex; gap: 15px;">
                    <div class="form-group" style="flex: 1;">
                        <label>Zona Eleitoral (Apenas Leitura)</label>
                        <input type="text" value="<%= usuario.zona || '-' %>" disabled style="background-color: #eee; font-weight: bold; color: #2c3e50;">
                    </div>
                    <div class="form-group" style="flex: 1;">
                        <label>Seção Eleitoral (Apenas Leitura)</label>
                        <input type="text" value="<%= usuario.secao || '-' %>" disabled style="background-color: #eee; font-weight: bold; color: #2c3e50;">
                    </div>
                </div>

                <div class="instructions-container" style="display: flex; gap: 15px;">
                    <div class="form-group" style="flex: 1;">
                        <label>Estado (UF)</label>
                        <select id="estado" name="estado" data-uf-salva="<%= usuario.estado %>" disabled required style="width: 100%; padding: 10px; border-radius: 4px; border: 1px solid #ccc;">
                            <option value="">Selecione um estado</option>
                        </select>
                    </div>
                    <div class="form-group" style="flex: 2;">
                        <label>Cidade</label>
                        <select id="cidade" name="cidade" data-cidade-salva="<%= usuario.cidade %>" disabled required style="width: 100%; padding: 10px; border-radius: 4px; border: 1px solid #ccc;">
                            <option value="">Selecione uma cidade</option>
                        </select>
                    </div>
                </div>

                <div class="form-group">
                    <label>Situação do Voto e Comprovantes</label>
                    <div style="margin-top: 10px; display: flex; flex-direction: column; gap: 10px;">
                        
                        <div style="display: flex; justify-content: space-between; align-items: center; padding: 10px; border: 1px solid #ccc; border-radius: 4px; background: #fff;">
                            <div>
                                <strong>Eleições Gerais:</strong><br>
                                <% if (usuario.votouGeral) { %>
                                    <span style="color: #2ecc71; font-weight: bold;">● Voto Registrado</span>
                                <% } else { %>
                                    <span style="color: #e74c3c; font-weight: bold;">○ Pendente</span>
                                <% } %>
                            </div>
                            <% if (usuario.votouGeral) { %>
                                <button type="button" onclick="gerarComprovantePerfil('Geral')" class="btn btn-primary" style="background-color: #3498db; padding: 8px 15px; font-size: 0.9rem;">
                                    📄 Baixar PDF
                                </button>
                            <% } %>
                        </div>

                        <div style="display: flex; justify-content: space-between; align-items: center; padding: 10px; border: 1px solid #ccc; border-radius: 4px; background: #fff;">
                            <div>
                                <strong>Eleições Municipais:</strong><br>
                                <% if (usuario.votouMunicipal) { %>
                                    <span style="color: #2ecc71; font-weight: bold;">● Voto Registrado</span>
                                <% } else { %>
                                    <span style="color: #e74c3c; font-weight: bold;">○ Pendente</span>
                                <% } %>
                            </div>
                            <% if (usuario.votouMunicipal) { %>
                                <button type="button" onclick="gerarComprovantePerfil('Municipal')" class="btn btn-primary" style="background-color: #3498db; padding: 8px 15px; font-size: 0.9rem;">
                                    📄 Baixar PDF
                                </button>
                            <% } %>
                        </div>

                    </div>
                </div>

                <% if (tipoAcesso === 'Candidato' && usuario.cargo) { %>
                    <div class="instruction-item" style="text-align: left; margin-bottom: 20px; background-color: #f0f7ff;">
                        <h4 style="color: #3498db;">Dados da Candidatura</h4>
                        <p><strong>Cargo:</strong> <%= usuario.cargo %></p>
                        <p><strong>Número:</strong> <%= usuario.numero %></p>
                        <p><strong>Status:</strong> <%= usuario.status %></p>
                    </div>
                <% } %>

                <button type="submit" class="btn btn-primary" style="width: 100%; margin-top: 15px;">Salvar Alterações</button>
            </form>
        </div>
    </main>

    <div id="area-comprovante" style="display:none;">
        <div id="comprovante-pdf" style="padding: 30px; font-family: 'Courier New', Courier, monospace; color: #000; width: 400px; background: #fff; border: 2px solid #000;">
            <div style="text-align: center; border-bottom: 2px dashed #000; padding-bottom: 15px; margin-bottom: 20px;">
                <h2 style="margin: 0;">JUSTIÇA ELEITORAL</h2>
                <h4 style="margin: 5px 0 0 0;">Comprovante de Votação</h4>
            </div>
            <p style="margin-bottom: 8px;"><strong>Eleitor:</strong> <%= usuario.nome %></p>
            <p style="margin-bottom: 8px;"><strong>CPF:</strong> <%= usuario.cpf.replace(/(\d{3})\.(\d{3})\.(\d{3})-(\d{2})/, '***.$2.$3-**') %></p>
            <p style="margin-bottom: 8px;"><strong>Eleição:</strong> <span id="comp-eleicao"></span></p>
            <p style="margin-bottom: 8px;"><strong>Zona/Seção:</strong> <%= usuario.zona %> / <%= usuario.secao %></p>
            <p style="margin-bottom: 8px;"><strong>Emitido em:</strong> <span id="comp-data"></span></p>
            <hr style="border-top: 1px dashed #000; margin: 20px 0;">
            <p style="font-size: 0.85rem; text-align: center; word-break: break-all;">
                CÓDIGO DE AUTENTICAÇÃO<br>
                <strong id="comp-hash"></strong>
            </p>
        </div>
    </div>

    <script>
        
        function gerarComprovantePerfil(tipo) {
            const dataAtual = new Date().toLocaleString('pt-BR');
            document.getElementById('comp-data').innerText = dataAtual;
            document.getElementById('comp-eleicao').innerText = tipo;
            
            
            const idUsuario = "<%= usuario._id %>".substring(0,8).toUpperCase();
            const hash = idUsuario + "-" + btoa(tipo).toUpperCase();
            document.getElementById('comp-hash').innerText = hash;

            const elemento = document.getElementById('comprovante-pdf');
            const area = document.getElementById('area-comprovante');
            
            area.style.display = 'block'; 
            
            const opcoes = {
                margin: 10,
                filename: `Comprovante_Eleicoes_${tipo}.pdf`,
                image: { type: 'jpeg', quality: 0.98 },
                html2canvas: { scale: 2 },
                jsPDF: { unit: 'mm', format: 'a5', orientation: 'portrait' }
            };

            html2pdf().set(opcoes).from(elemento).save().then(() => {
                area.style.display = 'none'; 
            });
        }

        
        const estadoSelect = document.getElementById("estado");
        const cidadeSelect = document.getElementById("cidade");
        
        const ufSalva = estadoSelect.getAttribute("data-uf-salva");
        const cidadeSalva = cidadeSelect.getAttribute("data-cidade-salva");

        function carregarCidades(uf, preSelecionar = '') {
            cidadeSelect.innerHTML = '<option value="">Carregando...</option>';
            cidadeSelect.disabled = true; 
            
            fetch(`https://servicodados.ibge.gov.br/api/v1/localidades/estados/${uf}/municipios`)
                .then(res => res.json())
                .then(cidades => {
                    cidadeSelect.innerHTML = '<option value="">Selecione uma cidade</option>';
                    cidades.forEach(cidade => {
                        const option = document.createElement("option");
                        option.value = cidade.nome;
                        option.textContent = cidade.nome;
                        if (cidade.nome === preSelecionar) {
                            option.selected = true;
                        }
                        cidadeSelect.appendChild(option);
                    });
                })
                .catch(err => console.error("Erro ao carregar cidades:", err));
        }

        fetch("https://servicodados.ibge.gov.br/api/v1/localidades/estados?orderBy=nome")
            .then(res => res.json())
            .then(estados => {
                estados.forEach(uf => {
                    const option = document.createElement("option");
                    option.value = uf.sigla;
                    option.textContent = uf.nome;
                    if (uf.sigla === ufSalva) {
                        option.selected = true;
                    }
                    estadoSelect.appendChild(option);
                });

                if (ufSalva) {
                    carregarCidades(ufSalva, cidadeSalva);
                }
            })
            .catch(err => console.error("Erro ao carregar estados:", err));

        estadoSelect.addEventListener("change", () => {
            const uf = estadoSelect.value;
            if (uf) {
                carregarCidades(uf);
            } else {
                cidadeSelect.innerHTML = '<option value="">Selecione uma cidade</option>';
                cidadeSelect.disabled = true;
            }
        });
    </script>
</body>
</html>