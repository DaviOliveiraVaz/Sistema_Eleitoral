<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <title>Meu Perfil</title>
    <link rel="stylesheet" href="/style.css">
</head>
<body>
    <%- include('navbar') %>

    <main class="content-area">
        <div class="login-wrapper" style="max-width: 700px; margin: 0 auto;">
            <header class="login-header">
                <h1>Meus Dados</h1>
                <p>Gerencie suas informações pessoais</p>
            </header>

            <form action="/perfil/editar" method="POST" style="padding: 30px;">
                <div class="form-group">
                    <label>Nome Completo</label>
                    <input type="text" name="nome" value="<%= usuario.nome %>" required disabled>
                </div>

                <div style="display: flex; gap: 15px;">
                    <div class="form-group" style="flex: 1;">
                        <label>CPF</label>
                        <input type="text" value="<%= usuario.cpf %>" disabled style="background-color: #eee;">
                    </div>
                    <div class="form-group" style="flex: 1;">
                        <label>Data de Nascimento</label>
                        <% 
                            let dataFormatada = '';
                            if (usuario.dataNascimento) {
                                const d = new Date(usuario.dataNascimento);
                                dataFormatada = d.toISOString().split('T')[0];
                            }
                        %>
                        <input type="date" name="dataNascimento" value="<%= dataFormatada %>" required style="width: 100%; padding: 10px; border: 1px solid #ccc; border-radius: 4px;" disabled>
                    </div>
                </div>

                <div class="form-group">
                    <label>Idade Atual</label>
                    <input type="number" value="<%= usuario.idade %>" disabled style="background-color: #eee;">
                </div>

                <div class="form-group">
                    <label>Sexo</label>
                    <select name="sexo" required style="width: 100%; padding: 10px; border-radius: 4px; border: 1px solid #ccc;">
                        <option value="" disabled <%= !usuario.sexo ? 'selected' : '' %>>Selecione</option>
                        <option value="Masculino" <%= usuario.sexo === 'Masculino' ? 'selected' : '' %>>Masculino</option>
                        <option value="Feminino" <%= usuario.sexo === 'Feminino' ? 'selected' : '' %>>Feminino</option>
                    </select>
                </div>

                <% if (tipoAcesso === 'Eleitor') { %>
                    <div class="instructions-container" style="display: flex; gap: 15px;">
                        <div class="form-group" style="flex: 1;">
                            <label>Zona Eleitoral (Apenas Leitura)</label>
                            <input type="text" value="<%= usuario.zona || '-' %>" disabled style="background-color: #eee;">
                        </div>
                        <div class="form-group" style="flex: 1;">
                            <label>Seção Eleitoral (Apenas Leitura)</label>
                            <input type="text" value="<%= usuario.secao || '-' %>" disabled style="background-color: #eee;">
                        </div>
                    </div>
                <% } %>

                <div class="instructions-container" style="display: flex; gap: 15px;">
                    <div class="form-group" style="flex: 1;">
                        <label>Estado (UF)</label>
                        <select id="estado" name="estado" data-uf-salva="<%= usuario.estado %>" required style="width: 100%; padding: 10px; border-radius: 4px; border: 1px solid #ccc;" disabled>
                            <option value="">Selecione um estado</option>
                        </select>
                    </div>
                    <div class="form-group" style="flex: 2;">
                        <label>Cidade</label>
                        <select id="cidade" name="cidade" data-cidade-salva="<%= usuario.cidade %>" required style="width: 100%; padding: 10px; border-radius: 4px; border: 1px solid #ccc;" disabled>
                            <option value="">Selecione uma cidade</option>
                        </select>
                    </div>
                </div>

                <div class="form-group">
                    <label>Situação do Voto</label>
                    <div style="margin-top: 5px;">
                        <% if (usuario.votou) { %>
                            <span class="status-aprovado" style="background-color: #d4edda; padding: 6px 12px; border-radius: 4px;">
                                ● Voto Confirmado
                            </span>
                        <% } else { %>
                            <span class="status-rejeitado" style="background-color: #f8d7da; padding: 6px 12px; border-radius: 4px;">
                                ○ Ainda não votou
                            </span>
                        <% } %>
                    </div>
                </div>

                <% if (tipoAcesso === 'Candidato' && usuario.cargo) { %>
                    <div class="instruction-item" style="text-align: left; margin-bottom: 20px; background-color: #f0f7ff;">
                        <h4 style="color: #3498db;">Dados da Candidatura</h4>
                        <p><strong>Cargo:</strong> <%= usuario.cargo %></p>
                        <p><strong>Número:</strong> <%= usuario.numero %></p>
                        <p><strong>Status:</strong> <%= usuario.status %></p>
                    </div>
                <% } %>

                <button type="submit" class="btn btn-primary" style="width: 100%; margin-top: 15px;">Salvar Alterações</button>
            </form>
        </div>
    </main>

    <script>
        const estadoSelect = document.getElementById("estado");
        const cidadeSelect = document.getElementById("cidade");
        
        const ufSalva = estadoSelect.getAttribute("data-uf-salva");
        const cidadeSalva = cidadeSelect.getAttribute("data-cidade-salva");

        function carregarCidades(uf, preSelecionar = '') {
            cidadeSelect.innerHTML = '<option value="">Carregando...</option>';
            cidadeSelect.disabled = true;
            fetch(`https://servicodados.ibge.gov.br/api/v1/localidades/estados/${uf}/municipios`)
                .then(res => res.json())
                .then(cidades => {
                    cidadeSelect.innerHTML = '<option value="">Selecione uma cidade</option>';
                    cidades.forEach(cidade => {
                        const option = document.createElement("option");
                        option.value = cidade.nome;
                        option.textContent = cidade.nome;
                        if (cidade.nome === preSelecionar) {
                            option.selected = true;
                        }
                        cidadeSelect.appendChild(option);
                    });
                })
                .catch(err => console.error("Erro ao carregar cidades:", err));
        }

        fetch("https://servicodados.ibge.gov.br/api/v1/localidades/estados?orderBy=nome")
            .then(res => res.json())
            .then(estados => {
                estados.forEach(uf => {
                    const option = document.createElement("option");
                    option.value = uf.sigla;
                    option.textContent = uf.nome;
                    if (uf.sigla === ufSalva) {
                        option.selected = true;
                    }
                    estadoSelect.appendChild(option);
                });

                if (ufSalva) {
                    carregarCidades(ufSalva, cidadeSalva);
                }
            })
            .catch(err => console.error("Erro ao carregar estados:", err));

        estadoSelect.addEventListener("change", () => {
            const uf = estadoSelect.value;
            if (uf) {
                carregarCidades(uf);
            } else {
                cidadeSelect.innerHTML = '<option value="">Selecione uma cidade</option>';
                cidadeSelect.disabled = true;
            }
        });
    </script>
</body>
</html>