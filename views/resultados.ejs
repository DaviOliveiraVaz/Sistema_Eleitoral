<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Resultados da Eleição</title>
    <link rel="stylesheet" href="/style.css">
    <script src="https://cdnjs.cloudflare.com/ajax/libs/html2pdf.js/0.10.1/html2pdf.bundle.min.js"></script>
</head>
<body>
    <%- include('navbar') %>

    <div class="container">
        <div class="view active">
            <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px;">
                <h2>Resultados Parciais - <%= nomeEleicao %></h2>
                <button class="btn btn-primary" onclick="gerarPDF()" style="padding: 10px 15px; background-color: #3498db; color: white; border: none; border-radius: 4px; cursor: pointer;">Baixar Relatório em PDF</button>
            </div>

            <div id="conteudo-relatorio" style="padding: 10px; background: #fff; border-radius: 8px;">
                <div class="comprovante-header" style="text-align: center; margin-bottom: 20px; display: none;" id="pdf-header">
                    <h3>TRIBUNAL REGIONAL ELEITORAL</h3>
                    <p>Relatório Oficial de Apuração dos Votos</p>
                    <hr>
                </div>

                <% for (let cargo in resultadosPorCargo) { %>
                    <% const candidatosDoCargo = resultadosPorCargo[cargo]; %>
                    <% if (candidatosDoCargo.length > 0) { %>
                        <h3 class="section-title" style="color: #3498db; border-color: #3498db;"><%= cargo %></h3>

                        <!-- PAINEL DE ESTATÍSTICAS -->
                        <% if (estatisticas && estatisticas[cargo]) { %>
                            <div style="display: flex; gap: 15px; margin-bottom: 20px; justify-content: space-between; background: #f8f9fa; padding: 15px; border-radius: 8px; border: 1px solid #eee;">
                                <div style="text-align: center; flex: 1;">
                                    <span style="display: block; font-size: 0.9rem; color: #7f8c8d;">Total Apurado</span>
                                    <strong style="font-size: 1.5rem; color: #2c3e50;"><%= estatisticas[cargo].total %></strong>
                                </div>
                                <div style="text-align: center; flex: 1; border-left: 1px solid #ccc; border-right: 1px solid #ccc;">
                                    <span style="display: block; font-size: 0.9rem; color: #7f8c8d;">Votos Válidos</span>
                                    <strong style="font-size: 1.5rem; color: #2ecc71;"><%= estatisticas[cargo].validos %></strong>
                                </div>
                                <div style="text-align: center; flex: 1; border-right: 1px solid #ccc;">
                                    <span style="display: block; font-size: 0.9rem; color: #7f8c8d;">Em Branco</span>
                                    <strong style="font-size: 1.5rem; color: #95a5a6;"><%= estatisticas[cargo].brancos %></strong>
                                </div>
                                <div style="text-align: center; flex: 1;">
                                    <span style="display: block; font-size: 0.9rem; color: #7f8c8d;">Nulos</span>
                                    <strong style="font-size: 1.5rem; color: #e74c3c;"><%= estatisticas[cargo].nulos %></strong>
                                </div>
                            </div>
                        <% } %>

                        <div class="instructions-container">
                            <div class="instruction-item" style="text-align: left;">
                                <h4>Ranking de Candidatos</h4>
                                <ul style="list-style: none; padding: 0; line-height: 2;">
                                    <% candidatosDoCargo.forEach((candidato, index) => { %>
                                        <li>
                                            <strong><%= index + 1 %>º</strong> - 
                                            <%= candidato.nome %> (<%= candidato.numero %>) - 
                                            <strong class="status-aprovado"><%= candidato.votos %> votos</strong>
                                        </li>
                                    <% }) %>
                                </ul>
                            </div>

                            <div class="instruction-item" style="display: flex; justify-content: center; background-color: #fff;">
                                <canvas id="grafico-<%= cargo.replace(/\s/g, '') %>" width="250" height="250"></canvas>
                            </div>
                        </div>
                    <% } %>
                <% } %>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        const dadosCompletos = <%- JSON.stringify(resultadosPorCargo) %>;
        const cores = ['#3498db', '#e74c3c', '#f1c40f', '#2ecc71', '#9b59b6', '#e67e22'];

        for (let cargo in dadosCompletos) {
            const candidatos = dadosCompletos[cargo];
            if (candidatos.length > 0) {
                const canvasId = 'grafico-' + cargo.replace(/\s/g, '');
                const ctx = document.getElementById(canvasId).getContext('2d');
                new Chart(ctx, {
                    type: 'pie',
                    data: {
                        labels: candidatos.map(c => c.nome),
                        datasets: [{
                            data: candidatos.map(c => c.votos),
                            backgroundColor: cores.slice(0, candidatos.length)
                        }]
                    },
                    options: { 
                        responsive: false,
                        animation: false // <-- O SEGREDO QUE RESOLVE A CORRUPÇÃO DO PDF
                    }
                });
            }
        }

        function gerarPDF() {
            const header = document.getElementById('pdf-header');
            header.style.display = 'block';

            const elemento = document.getElementById('conteudo-relatorio');
            const opcoes = {
                margin: 10,
                filename: 'Apuracao_Eleicoes_2026.pdf',
                image: { type: 'jpeg', quality: 0.98 },
                html2canvas: { scale: 2, useCORS: true },
                jsPDF: { unit: 'mm', format: 'a4', orientation: 'portrait' }
            };

            html2pdf().set(opcoes).from(elemento).save().then(() => {
                header.style.display = 'none';
            }).catch(err => {
                console.error("Erro ao gerar PDF:", err);
                alert("Ocorreu um erro ao gerar o PDF.");
                header.style.display = 'none';
            });
        }
    </script>
</body>
</html>