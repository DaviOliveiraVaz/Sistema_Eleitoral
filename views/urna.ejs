<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Urna Eletrônica</title>
    <link rel="stylesheet" href="style.css">
</head>
<body class="urna-page">
    <div id="urna" class="view active">
        <h2>Votação</h2>
        <div class="container">
            <div class="urna-container">
                <div class="urna-tela">
                    <div class="tela-header">Seu voto para<br><br>REPRESENTANTE</div>
                    <div class="tela-numeros">
                        <div class="digito" id="digito1"></div>
                        <div class="digito" id="digito2"></div>
                    </div>
                    <div id="info-candidato" style="font-size: 1.2rem; font-weight: bold; min-height: 60px;"></div>
                    <div class="tela-rodape">Aperte a tecla:<br>VERDE para CONFIRMAR<br>LARANJA para CORRIGIR</div>
                </div>
                <div class="urna-teclado">
                    <div class="teclado-numeros">
                        <% [1,2,3,4,5,6,7,8,9].forEach(n => { %>
                            <button class="tecla" onclick="inserirNumero('<%= n %>')"><%= n %></button>
                        <% }) %>
                        <div></div><button class="tecla" onclick="inserirNumero('0')">0</button><div></div>
                    </div>
                    <div class="teclado-acoes">
                        <button class="tecla-acao tecla-branco" onclick="votarBranco()">Branco</button>
                        <button class="tecla-acao tecla-corrige" onclick="corrigirVoto()">Corrige</button>
                        <button class="tecla-acao tecla-confirma" onclick="confirmarVoto()">Confirma</button>
                    </div>
                </div>
            </div>
        </div>
        <br><a href="/login">← Voltar</a>
    </div>

    <script>
        const candidatos = <%- JSON.stringify(candidatos) %>;
        let votoAtual = "";

        function atualizarTela() {
            document.getElementById('digito1').innerText = votoAtual[0] || "";
            document.getElementById('digito2').innerText = votoAtual[1] || "";
            const info = document.getElementById('info-candidato');
            
            if (votoAtual.length === 2) {
                const c = candidatos.find(cand => cand.numero == votoAtual);
                info.innerText = c ? `Candidato: ${c.nome} (${c.partido})` : "VOTO NULO";
            } else { info.innerText = ""; }
        }

        function inserirNumero(num) { if (votoAtual.length < 2) { votoAtual += num; atualizarTela(); } }
        function corrigirVoto() { votoAtual = ""; atualizarTela(); }
        function votarBranco() { votoAtual = "BR"; document.getElementById('info-candidato').innerText = "VOTO EM BRANCO"; }

        function confirmarVoto() {
            if (votoAtual.length === 2 || votoAtual === "BR") {
                alert("FIM! Voto computado com sucesso.");
                window.location.href = "/resultados";
            } else { alert("Digite o número completo."); }
        }
    </script>
</body>
</html>