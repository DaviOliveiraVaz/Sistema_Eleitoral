<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Urna Eletrônica</title>
    <link rel="stylesheet" href="/style.css">
    <style>
        .urna-wrapper {
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: calc(100vh - 80px);
            padding: 20px;
        }

        .digito.pisca {
            animation: piscaCursor 1s infinite;
            border-bottom: 4px solid #333;
        }

        @keyframes piscaCursor {
            0%, 49% { opacity: 1; }
            50%, 100% { opacity: 0; }
        }

        .info-candidato {
            min-height: 100px;
            font-size: 1.2rem;
            font-weight: bold;
            color: #333;
            line-height: 1.5;
            margin-top: 15px;
        }

        .voto-branco-msg {
            font-size: 2.5rem;
            font-weight: bold;
            text-align: center;
            margin-top: 40px;
            animation: piscaLento 1.5s infinite;
        }

        .tela-fim {
            font-size: 6rem;
            font-weight: bold;
            text-align: center;
            margin-top: 80px;
            display: none;
            color: #111;
            animation: piscaLento 1.5s infinite;
        }

        @keyframes piscaLento {
            0%, 49% { opacity: 1; }
            50%, 100% { opacity: 0.5; }
        }
    </style>
</head>
<body>
    <%- include('navbar') %>

    <div class="urna-wrapper">
        <div class="urna-container">
            
            <!-- TELA DA URNA -->
            <div class="urna-tela">
                <!-- Flexbox inserido para separar dados (esquerda) e foto (direita) -->
                <div id="tela-voto" style="display: flex; justify-content: space-between; height: 100%;">
                    
                    <div style="flex: 1;">
                        <div class="tela-header">
                            <span style="font-size: 1rem; font-weight: normal;">Seu voto para</span><br>
                            <span id="cargo-nome" style="font-size: 1.5rem; margin-top: 5px; display: inline-block;">DEPUTADO ESTADUAL</span>
                        </div>

                        <div class="tela-numeros" id="tela-numeros">
                            <!-- JS injeta os digitos aqui -->
                        </div>

                        <div id="info-candidato" class="info-candidato"></div>
                    </div>

                    <!-- DIV DA FOTO (Fica oculta até achar um candidato) -->
                    <div id="foto-candidato-container" style="display: none; flex-direction: column; align-items: center; margin-left: 15px;">
                        <div style="width: 110px; height: 150px; border: 2px solid #333; background-color: #fff; padding: 2px; box-shadow: 2px 2px 0px rgba(0,0,0,0.2);">
                            <!-- Avatar cinza padrão -->
                            <img src="https://cdn.pixabay.com/photo/2015/10/05/22/37/blank-profile-picture-973460_960_720.png" alt="Foto do Candidato" style="width: 100%; height: 100%; object-fit: cover; filter: grayscale(100%);">
                        </div>
                        <span style="font-size: 0.7rem; margin-top: 5px; font-weight: bold; text-align: center;">FOTO PADRÃO</span>
                    </div>

                </div>
                
                <div id="tela-fim" class="tela-fim">FIM</div>

                <div class="tela-rodape" id="tela-rodape">
                    Aperte a tecla:<br>
                    VERDE para CONFIRMAR<br>
                    LARANJA para CORRIGIR
                </div>
            </div>

            <!-- TECLADO DA URNA -->
            <div class="urna-teclado">
                <div class="teclado-numeros">
                    <button class="tecla" onclick="inserirNumero(1)">1</button>
                    <button class="tecla" onclick="inserirNumero(2)">2</button>
                    <button class="tecla" onclick="inserirNumero(3)">3</button>
                    <button class="tecla" onclick="inserirNumero(4)">4</button>
                    <button class="tecla" onclick="inserirNumero(5)">5</button>
                    <button class="tecla" onclick="inserirNumero(6)">6</button>
                    <button class="tecla" onclick="inserirNumero(7)">7</button>
                    <button class="tecla" onclick="inserirNumero(8)">8</button>
                    <button class="tecla" onclick="inserirNumero(9)">9</button>
                    <div></div>
                    <button class="tecla" onclick="inserirNumero(0)">0</button>
                    <div></div>
                </div>

                <div class="teclado-acoes">
                    <button class="tecla-acao tecla-branco" onclick="votarBranco()">Branco</button>
                    <button class="tecla-acao tecla-corrige" onclick="corrigirVoto()">Corrige</button>
                    <button class="tecla-acao tecla-confirma" onclick="confirmarVoto()">Confirma</button>
                </div>
            </div>

        </div>
    </div>

    <script>
        const tipoEleicao = "<%- tipoEleicao %>";

        const cargos = tipoEleicao === "Municipal"
            ? [
                { nome: "Vereador",  chave: "vereador",  digitos: 5 },
                { nome: "Prefeito",  chave: "prefeito",  digitos: 2 }
              ]
            : [
                { nome: "Deputado Estadual", chave: "deputadoEstadual", digitos: 5 },
                { nome: "Deputado Federal",  chave: "deputadoFederal",  digitos: 4 },
                { nome: "Senador",           chave: "senador",           digitos: 3 },
                { nome: "Governador",        chave: "governador",        digitos: 2 },
                { nome: "Presidente",        chave: "presidente",        digitos: 2 }
              ];

        let etapaAtual = 0;
        let votoAtual = "";
        let isBranco = false;
        let votos = {};
        
        const candidatos = <%- JSON.stringify(Candidatos) %>;

        function atualizarTela() {
            if (etapaAtual >= cargos.length) return;

            const etapa = cargos[etapaAtual];
            document.getElementById("cargo-nome").innerText = etapa.nome.toUpperCase();
            
            const containerNumeros = document.getElementById("tela-numeros");
            const info = document.getElementById("info-candidato");
            const fotoContainer = document.getElementById("foto-candidato-container");
            
            containerNumeros.style.display = "flex";
            containerNumeros.innerHTML = "";
            info.innerHTML = "";
            fotoContainer.style.display = "none"; // Sempre esconde a foto ao resetar a tela

            if (isBranco) {
                containerNumeros.style.display = "none";
                info.innerHTML = `<div class="voto-branco-msg">VOTO EM BRANCO</div>`;
                return;
            }

            for (let i = 0; i < etapa.digitos; i++) {
                const div = document.createElement("div");
                div.classList.add("digito");
                
                if (votoAtual[i]) {
                    div.innerText = votoAtual[i];
                } else if (i === votoAtual.length) {
                    div.classList.add("pisca");
                }
                containerNumeros.appendChild(div);
            }

            if (votoAtual.length === etapa.digitos) {
                const candidato = candidatos.find(c =>
                    c.numero == votoAtual &&
                    c.cargo === etapa.nome &&
                    c.status === "Homologado" &&
                    c.ativo !== false
                );

                if (candidato) {
                    info.innerHTML = `
                        Nome: ${candidato.nome}<br>
                        Partido: ${candidato.partido}<br>
                        <span style="font-size: 0.9rem; font-weight: normal; margin-top:10px; display:block;">
                            Local: ${candidato.cidade} - ${candidato.estado}
                        </span>
                    `;
                    // Exibe a foto padrão quando encontra um candidato válido
                    fotoContainer.style.display = "flex";
                } else {
                    info.innerHTML = `<div style="font-size: 1.8rem; margin-top: 15px; animation: piscaLento 1.5s infinite;">NÚMERO ERRADO<br>VOTO NULO</div>`;
                }
            }
        }

        function inserirNumero(num) {
            if (isBranco) return; 
            if (votoAtual.length < cargos[etapaAtual].digitos) {
                votoAtual += num;
                atualizarTela();
            }
        }

        function corrigirVoto() {
            votoAtual = "";
            isBranco = false;
            atualizarTela();
        }

        function votarBranco() {
            if (votoAtual === "") {
                isBranco = true;
                atualizarTela();
            } else {
                alert("Para votar em BRANCO, o campo de voto deve estar vazio. Aperte CORRIGE e depois BRANCO.");
            }
        }

        function confirmarVoto() {
            const etapa = cargos[etapaAtual];
            let votoConfirmado = null;

            if (isBranco) {
                votoConfirmado = null;
            } else if (votoAtual.length === etapa.digitos) {
                votoConfirmado = votoAtual;
            } else {
                alert("Para confirmar, digite o número completo ou vote em BRANCO.");
                return;
            }

            votos[etapa.chave] = votoConfirmado;
            
            etapaAtual++;
            votoAtual = "";
            isBranco = false;

            if (etapaAtual < cargos.length) {
                atualizarTela();
            } else {
                finalizarVotacao();
            }
        }

        function finalizarVotacao() {
            document.getElementById("tela-voto").style.display = "none";
            document.getElementById("tela-rodape").style.display = "none";
            
            const telaFim = document.getElementById("tela-fim");
            telaFim.style.display = "block";

            setTimeout(() => {
                enviarVotos();
            }, 2500); 
        }

        async function enviarVotos() {
            try {
                const response = await fetch("/votar", {
                    method: "POST",
                    headers: { "Content-Type": "application/json" },
                    body: JSON.stringify(votos)
                });
                const data = await response.json();
                if (!response.ok) throw new Error(data.message);
                
                window.location.href = "/resultados";
            } catch (err) {
                alert("Erro ao computar voto: " + err.message);
                window.location.href = "/";
            }
        }

        atualizarTela();
    </script>
</body>
</html>